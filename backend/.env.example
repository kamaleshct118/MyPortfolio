# ============================================================
# backend/.env.example — Copy to .env and fill in real values
# NEVER commit .env — only commit this example file
# ============================================================

# ── LLM (Groq) ──────────────────────────────────────────────
MODEL_NAME=llama-3.3-70b-versatile
GROQ_API_KEY=your_groq_api_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1

# ── Embedding Model ─────────────────────────────────────────
EMBED_MODEL=nomic-ai/nomic-embed-text-v1.5

# ── Admin Auth ───────────────────────────────────────────────
# Use a strong random key: python -c "import secrets; print(secrets.token_hex(24))"
ADMIN_SECRET_KEY=your_strong_secret_key_here

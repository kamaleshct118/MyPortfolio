node_modules/
frontend/node_modules/

# Build output
dist/
dist-ssr/
frontend/dist/
*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*


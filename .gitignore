*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
pip-log.txt
pip-delete-this-directory.txt

# Python virtual environments
venv/
.venv/
env/
ENV/

# ─── Backend — Generated & Sensitive Data ────────────────────
# Uploaded files (PDFs, docs, etc.)
backend/uploads/
uploads/

# Vector embeddings (large, generated at runtime)
backend/vectorstore/
vectorstore/

# SQLite database
backend/metadata.db
*.db
*.sqlite
*.sqlite3



